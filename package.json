{
  "name": "lx-scene-setter",
  "version": "1.0.0",
  "description": "House-lighting controller with automatic Art-Net console failover, controlled over OSC (Companion).",
  "main": "src/index.js",
  "bin": {
    "scene-setter": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "concurrently -n engine,ui -c blue,magenta \"npm:dev:engine\" \"npm:dev:ui\"",
    "dev:engine": "node --watch src/index.js",
    "dev:ui": "npm --prefix ui run dev",
    "ui:build": "npm --prefix ui run build",
    "build": "npm --prefix ui install && npm --prefix ui run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "osc": "^2.4.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "license": "MIT"
}
